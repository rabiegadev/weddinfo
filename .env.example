# Neon Postgres (Connection string z panelu Neon).
# Używany przez Next.js i przez Drizzle CLI — trzymaj go w .env LUB .env.local (oba działają po poprawce drizzle.config).
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Losowy sekret (min. 16 znaków) — podpisywanie ciasteczka podglądu zapytania
WEDDINFO_COOKIE_SECRET="zmien-na-dlugi-losowy-ciag-znakow"

# Opcjonalnie lokalnie: pokaż hasło gościa na ekranie po wysłaniu (NIE włączaj w produkcji)
# WEDDINFO_DEV_RETURN_PASSWORD="true"

# Panel admin: hash hasła (bcrypt). Wygeneruj: npm run admin:hash-password
WEDDINFO_ADMIN_PASSWORD_HASH=""

# Opcjonalnie: pełny URL strony (linki w mailu i w panelu), jeśli nagłówki Host nie są dostępne
# NEXT_PUBLIC_SITE_URL="https://twoja-domena.pl"

# Wysyłka e-maili SMTP (np. SeoHost)
SMTP_HOST="mail.twoja-domena.pl"
# 465 dla SSL/TLS lub 587 dla STARTTLS
SMTP_PORT="465"
# Ustaw true dla 465, false dla 587
SMTP_SECURE="true"
SMTP_USER="powiadomienia@twoja-domena.pl"
SMTP_PASS=""
# Opcjonalnie jawny nadawca; domyślnie: Weddinfo <SMTP_USER>
# WEDDINFO_MAIL_FROM="Weddinfo <powiadomienia@twoja-domena.pl>"
WEDDINFO_MAIL_FROM=""

# Uploady zdjęć formularza (lokalny storage na serwerze):
# katalog zapisu plików na serwerze (upewnij się, że user procesu ma prawa zapisu)
# WEDDINFO_UPLOAD_DIR="/var/www/weddinfo/uploads/inquiries"
# publiczna baza URL do odczytu plików (domyślnie: /api/uploads/inquiries)
# WEDDINFO_UPLOAD_BASE_URL="https://twoja-domena.pl/api/uploads/inquiries"
